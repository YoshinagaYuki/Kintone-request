# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # サーバーのみ。クライアントへ露出禁止

# kintone
KINTONE_DOMAIN=                   # 例: xxxx.cybozu.com(https:// なし)
KINTONE_APP_ID=10                 # オールマイトアプリ
KINTONE_API_TOKEN=                # App10: フォーム参照+レコード追加/閲覧/編集

# kintone 採番マスタ・配送管理(承認時の採番・転記で使用)
KINTONE_APP_ID_NUMBERING=50       # 採番マスタ
KINTONE_APP_ID_SHIPPING=11        # 配送管理
KINTONE_API_TOKEN_APP50=          # App50: レコード閲覧+編集
KINTONE_API_TOKEN_APP11=          # App11: レコード閲覧+追加+編集

# kintone てずくーる(App49。フィールド一覧取得〜マッピング確定後の登録で使用)
KINTONE_API_TOKEN_APP49=          # App49: フォーム参照+レコード追加/閲覧/編集

# アプリ
APP_BASE_URL=                     # 例: https://xxxx.vercel.app(通知内の管理画面URLに使用)

# メール送信(入力者への申請完了/承認完了メール。Google Workspace SMTP / nodemailer)
# 未設定なら送信スキップ。認証情報はサーバーのみ・ブラウザへ渡さない
SMTP_HOST=                        # 例: smtp.gmail.com
SMTP_PORT=465                     # 465(SSL) / 587(STARTTLS)
SMTP_USER=                        # 例: contact@unity-corp.jp
SMTP_PASS=                        # アプリパスワード等
MAIL_FROM=                        # 例: 申請受付 <contact@unity-corp.jp>

# Web Push通知(VAPID鍵。未設定なら通知スキップ)
# 生成: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=                # サーバーのみ
VAPID_SUBJECT=                    # 例: mailto:y-yoshinaga@unity-corp.jp

# 共通通知サービス(登録完了通知。Webhook URLはコードに書かず必ずここで設定)
GOOGLE_CHAT_WEBHOOK_URL=          # Google Chat Incoming Webhook。未設定ならChat通知はスキップ
LINE_GAS_WEBHOOK_URL=             # 既存GAS(LINEグループ通知)のWebアプリURL。未設定ならLINE通知はスキップ
LINE_GAS_TOKEN=                   # GAS側で照合する任意トークン(GASが不要なら空でよい)
NOTIFY_API_TOKEN=                 # kintoneカスタマイズJSから通知APIを呼ぶ際の共有トークン

# LINE WORKS(Phase1では未使用・後回し)
LINEWORKS_BOT_ID=
LINEWORKS_CLIENT_ID=
LINEWORKS_CLIENT_SECRET=
LINEWORKS_SERVICE_ACCOUNT=
LINEWORKS_PRIVATE_KEY=
LINEWORKS_CHANNEL_ID=
